Options -Indexes
RewriteEngine On

# Force HTTPS (enable on production)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Block sensitive paths
RewriteRule ^includes/ - [F,L]
RewriteRule ^data/heckel/ - [F,L]
RewriteRule ^data/amr-meta\.json$ - [F,L]
RewriteRule ^data/amr-data\.json$ - [F,L]
RewriteRule ^data-json/?$ /data-json.php [L,QSA]
RewriteRule ^data/access-log\.json$ - [F,L]
RewriteRule ^data/users\.json$ - [F,L]
RewriteRule ^build-amr-data\.php$ - [F,L]

# Static assets pass through
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Clean URL routing
RewriteRule ^logout/?$ /index.php?logout=1 [L]
RewriteRule ^update/?$ /update.php [L,QSA]
RewriteRule ^changelog/?$ /changelog.php [L,QSA]
RewriteRule ^access-log/?$ /access-log.php [L,QSA]
RewriteRule ^autura-market-report/?$ /market.php [L,QSA]
RewriteRule ^customer-results/?$ /customer.php [L,QSA]
RewriteRule ^activity-90/?$ /activity.php [L,QSA]
RewriteRule ^market/?$ /autura-market-report [L,R=301]
